# Telegram bot token from @BotFather
BOT_TOKEN=123456:ABC-your-token-here

# Comma-separated Telegram user IDs allowed to use the bot.
# Find yours by writing to @userinfobot. The bot holds SSH keys, keep this tight.
ALLOWED_USER_IDS=11111111,22222222

# Master key for encrypting stored SSH secrets. Generate once and keep it secret:
#   python3 -c "import base64,os;print(base64.urlsafe_b64encode(os.urandom(32)).decode())"
# Losing it means re-adding all machines. Changing it invalidates stored keys.
MASTER_KEY=

# Optional default model (opus / sonnet / haiku). Empty = server default.
DEFAULT_MODEL=

# Path to the SQLite db inside the container (persisted via the bot-data volume).
DB_PATH=/data/bot.db
